# Copy to deploy/letta/.env before running `atelier letta up` if you need to customize the sidecar.
LETTA_IMAGE=letta/letta:latest
LETTA_CONTAINER_NAME=atelier-letta
LETTA_HOST_PORT=8283

# Set this in the Atelier process environment when Letta is the selected primary memory backend.
ATELIER_MEMORY_BACKEND=letta
LETTA_BASE_URL=http://127.0.0.1:8283
