ATELIER_ROOT=/var/lib/atelier
ATELIER_WORKSPACE_ROOT=/workspace
ATELIER_STORAGE_BACKEND=postgres
ATELIER_DATABASE_URL=postgresql://atelier:atelier@postgres:5432/atelier
ATELIER_SERVICE_ENABLED=true
ATELIER_REQUIRE_AUTH=true
ATELIER_API_KEY=replace-me
ATELIER_SERVICE_URL=http://atelier:8787
ATELIER_MCP_MODE=remote
ATELIER_OPENMEMORY_ENABLED=false
ATELIER_OPENMEMORY_MCP_SERVER_NAME=openmemory
